# PetirDashboard edge sync worker configuration.
# Copy to .env and fill in real values. This file is read by systemd via
# EnvironmentFile= (see edge/systemd/petir-sync.service). Keep the real .env
# out of version control. No secrets belong in this example.

# Lab server base URL (no trailing slash). The worker POSTs to /api/ingest/sync-batch.
SERVER_URL=https://lab-server.example.local

# Stable identity of THIS edge node. Must be registered in the server's edge_nodes table.
NODE_ID=rpi-lab-01

# Per-node bearer token issued by the server. Treat as a secret; do not commit the real value.
NODE_TOKEN=replace-with-node-token

# Path to the LIVE edge SQLite database on the Raspberry Pi.
EDGE_DB_PATH=/home/pi/weather-edge/data/db/weather_edge.db

# HTTP request timeout in seconds.
REQUEST_TIMEOUT_S=10

# Bounded retry within a single run (between-run backoff is the systemd timer interval).
MAX_RETRIES=3
BACKOFF_BASE_S=2
BACKOFF_CAP_S=30
