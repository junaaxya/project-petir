# Browser-facing API base URL.
#
# Production behind nginx (web + API on ONE origin): leave EMPTY so the
# dashboard calls the API with relative paths (/api/...). No CORS needed.
#
# Local split-port dev (next dev :3000, API :8000) is handled by
# .env.development which sets this to http://localhost:8000.
#
# NOTE: NEXT_PUBLIC_* is inlined at BUILD time. In Docker it is passed as a
# build ARG (see web/Dockerfile + docker-compose.yml), NOT a runtime env.
NEXT_PUBLIC_API_BASE=
