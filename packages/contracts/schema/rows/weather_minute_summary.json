{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "petir:rows/weather_minute_summary",
  "title": "WeatherMinuteSummaryRow",
  "description": "Per-minute weather aggregate. SUMMARY strategy: carries change_seq (monotonic, bumped by edge AFTER INSERT/UPDATE trigger). Natural key (node_id, db_epoch, minute_utc, source, device) for server upsert.",
  "type": "object",
  "additionalProperties": false,
  "required": ["change_seq", "minute_utc", "source", "device", "updated_at_utc"],
  "properties": {
    "change_seq": { "type": "integer", "minimum": 1, "description": "Monotonic sequence bumped on every insert/update of this row on the edge. Cursor for summary strategy. Guarantees late updates are never missed." },
    "minute_utc": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "device": { "type": "string" },
    "sample_count": { "type": ["integer", "null"] },
    "metric_sample_count": { "type": ["integer", "null"] },
    "valid_sample_count": { "type": ["integer", "null"] },
    "warn_sample_count": { "type": ["integer", "null"] },
    "invalid_sample_count": { "type": ["integer", "null"] },
    "status": { "oneOf": [ { "$ref": "petir:enums#/definitions/weather_status" }, { "type": "null" } ] },
    "degraded": { "type": ["boolean", "null"] },
    "temperature_avg": { "type": ["number", "null"] },
    "temperature_min": { "type": ["number", "null"] },
    "temperature_max": { "type": ["number", "null"] },
    "humidity_avg": { "type": ["number", "null"] },
    "humidity_min": { "type": ["number", "null"] },
    "humidity_max": { "type": ["number", "null"] },
    "pressure_avg": { "type": ["number", "null"] },
    "pressure_min": { "type": ["number", "null"] },
    "pressure_max": { "type": ["number", "null"] },
    "illuminance_avg": { "type": ["number", "null"] },
    "illuminance_min": { "type": ["number", "null"] },
    "illuminance_max": { "type": ["number", "null"] },
    "rain_max": { "type": ["number", "null"] },
    "wind_speed_avg": { "type": ["number", "null"] },
    "wind_speed_max": { "type": ["number", "null"] },
    "latest_wind_dir_deg": { "type": ["number", "null"] },
    "last_sample_ts_utc": { "type": ["string", "null"], "format": "date-time" },
    "updated_at_utc": { "type": "string", "format": "date-time" }
  }
}
