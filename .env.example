# PetirDashboard — Production environment for docker compose (server lab).
# Copy to .env and fill in REAL values. NEVER commit .env (see .gitignore).
#
# Generate strong secrets:
#   openssl rand -base64 24      # for POSTGRES_PASSWORD
#   openssl rand -hex 32         # for DASHBOARD_API_KEY (if used)

# --- Postgres ---
# Postgres is NOT published to the host (compose uses `expose`); only the
# server container reaches it over the compose network. No POSTGRES_PORT needed.
POSTGRES_USER=petir
POSTGRES_PASSWORD=CHANGE_ME_strong_random
POSTGRES_DB=petir

# --- Container host ports (nginx on the host proxies to these) ---
SERVER_PORT=8000
WEB_PORT=3000

# --- Dashboard auth (read-path) ---
# The dashboard is publicly reachable via Cloudflare Tunnel. Protect it.
# Option A (built-in): set DASHBOARD_AUTH_ENABLED=true + a strong DASHBOARD_API_KEY
#   (the browser must send it as the X-API-Key header).
# Option B (recommended): leave this false and gate the hostname with
#   Cloudflare Access (SSO/email) at the edge — see docs/production-checklist.md.
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_API_KEY=

# --- Ingest rate limiting (per node, sliding window) ---
RATE_LIMIT_PER_NODE=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- CORS ---
# Behind nginx, dashboard + API share ONE origin, so the browser uses relative
# /api paths and CORS is not exercised. Leave empty (or set the public origin
# only if you ever serve the API cross-origin).
CORS_ALLOW_ORIGINS=

# --- Web build-time API base ---
# Behind nginx (same origin), leave EMPTY → dashboard calls /api/... relative.
# This is consumed as a BUILD ARG by web/Dockerfile (NEXT_PUBLIC_* is inlined at
# build time), not a runtime env. Only set a full URL if the API is on a
# different origin than the dashboard.
NEXT_PUBLIC_API_BASE=
